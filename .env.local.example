ANTHROPIC_API_KEY=your_api_key_here

# Rate limiter (optional in dev; required in production to enforce per-IP limits).
# Provision an Upstash Redis instance (free tier is fine) and copy the REST URL + token here.
# Without these, /api/analyze fails open and allows unlimited requests.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
